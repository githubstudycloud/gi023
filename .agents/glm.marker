# GLM Agent Marker
# 此文件标记 GLM Agent 已在此项目中活跃
# 其他 Agent 读取此文件以了解当前项目状态

marker:
  agent: "glm"
  model: "glm-5.1"
  role: "primary"
  active: true
  marked_at: "2026-03-31"
  workspace: "D:\\2026033101"
  branch: "main"

# 当前状态
current_state:
  phase: "framework-setup"
  active_tasks: []
  completed_tasks: []

# 给其他 Agent 的消息
message_to_agents: |
  你好，我是 GLM，本项目的主 Agent。
  请在 .agents/identity.yml 中注册你的身份信息。
  请在 .agents/ 目录下创建你的 marker 文件。
  开发时请使用你自己的分支前缀（如 claude/xxx）。
  任务文件在 .agents/tasks/ 目录下读取。
